# ZYVO API (server-side only)
ZYVO_API_BASE_URL=https://app.zyvoerp.com/api
ZYVO_API_KEY=

# Public app URL for auth links
NEXT_PUBLIC_APP_URL=https://app.zyvoerp.com

# AI Content Engine
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_RATE_LIMIT=30
ADMIN_PASSWORD=change-me
ADMIN_JWT_SECRET=change-me-jwt-secret
CRON_SECRET=change-me-cron-secret
DATABASE_PATH=./data/ai-content.sqlite

# Google Analytics 4 + Search Console (Growth Analytics — dados reais, sem demo)
GA4_PROPERTY_ID=
GSC_SITE_URL=https://www.zyvoerp.com
# JSON completo da service account (uma linha) com acesso Viewer em GA4 e GSC
GOOGLE_SERVICE_ACCOUNT_JSON=
