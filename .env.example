# ─── ZYVO App API (obrigatório para signup + contacto) ───
ZYVO_API_BASE_URL=https://app.zyvoerp.com/api
ZYVO_API_KEY=

# URL pública da app (links de auth / redirects)
NEXT_PUBLIC_APP_URL=https://app.zyvoerp.com

# ─── Admin do site (painel /api/admin) ───
ADMIN_PASSWORD=change-me
ADMIN_JWT_SECRET=change-me-jwt-secret

# ─── Cron jobs (Vercel Cron ou scheduler externo) ───
CRON_SECRET=change-me-cron-secret

# ─── Base de dados SQLite (motor AI / blog / SEO) ───
DATABASE_PATH=./data/ai-content.sqlite

# ─── DeepSeek (geração de conteúdo AI — opcional) ───
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_RATE_LIMIT=30

# ─── IndexNow (indexação Bing/Yandex — opcional) ───
# Criar também public/{INDEXNOW_KEY}.txt com o mesmo valor
INDEXNOW_KEY=

# ─── Google Analytics 4 + Search Console (admin growth — opcional) ───
GA4_PROPERTY_ID=
GSC_SITE_URL=https://www.zyvoerp.com
GOOGLE_SERVICE_ACCOUNT_JSON=
